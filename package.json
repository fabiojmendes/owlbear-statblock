{
  "name": "owlbear-statblock",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "biome check --write src/",
    "preview": "vite preview",
    "prebuild": "npm run check",
    "build": "tsc -b && vite build",
    "predeploy": "npm run build",
    "deploy": "wrangler versions upload --preview-alias $(git branch --show-current)"
  },
  "dependencies": {
    "@owlbear-rodeo/sdk": "^3.1.0",
    "dice-typescript": "^1.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "wrangler": "^4.75.0"
  }
}
